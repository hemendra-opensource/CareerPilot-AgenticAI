# =============================================================
# CareerPilot AI — Environment Configuration
# =============================================================
# Copy this file to .env and fill in your values.
#
#   cp .env.example .env
#
# NEVER commit your actual .env file to version control.
# =============================================================

# ── Groq API ──────────────────────────────────────────────────
# Get your free API key at: https://console.groq.com/
GROQ_API_KEY=

# ── Groq Model ────────────────────────────────────────────────
# Recommended: llama-3.3-70b-versatile (fast, high quality)
# Alternatives: llama3-8b-8192  (faster, lower cost)
GROQ_MODEL=llama-3.3-70b-versatile
